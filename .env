
# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────
# Local :   mongodb://localhost:27017/ngo_tracker
# Atlas :   mongodb+srv://<user>:<pass>@cluster.mongodb.net/ngo_tracker
MONGODB_URI=mongodb://localhost:27017/ngo_tracker

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
